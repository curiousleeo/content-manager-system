DATABASE_URL=postgresql://user:password@localhost:5432/cms

# CORS — comma-separated list of allowed frontend origins
# Add your production domain alongside localhost, e.g.:
# ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# X (Twitter) API
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# Google / YouTube Data API v3
GOOGLE_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# xAI — required for Grok-powered research (trending topics, X conversation search)
# Get your key at: console.x.ai
XAI_API_KEY=
